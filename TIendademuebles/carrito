<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="Tienda online de muebles modernos y elegantes - Carrito de compras" />
    <meta name="author" content="" />
    <title>Muebles con Estilo - Carrito</title>
    <!-- Favicon-->
    <link rel="icon" type="image/x-icon" href="assets/favicon.ico" />
    <!-- Iconos de Bootstrap-->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.5.0/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- Tema CSS principal (incluye Bootstrap)-->
    <link href="css/styles.css" rel="stylesheet" />
    <style>
        .product-card:hover {
            transform: translateY(-5px);
            transition: transform 0.3s ease;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        }
        .cart-item-image {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 4px;
        }
        .quantity-input {
            max-width: 70px;
            text-align: center;
        }
    </style>
</head>

<body>
    <!-- Navegación-->
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <div class="container px-4 px-lg-5">
            <a class="navbar-brand fw-bold" href="Tiendaconestilo.html">
                <i class="bi bi-house-door-fill me-2"></i>Muebles con Estilo
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false"
                aria-label="Alternar navegación">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarSupportedContent">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                    <li class="nav-item"><a class="nav-link" href="Tiendaconestilo.html">Inicio</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" id="navbarDropdown" href="#" role="button"
                            data-bs-toggle="dropdown" aria-expanded="false">Categorías</a>
                        <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                            <li><a class="dropdown-item" href="Salon.html">Salón</a></li>
                            <li><a class="dropdown-item" href="Dormitorio.html">Dormitorio</a></li>
                            <li><a class="dropdown-item" href="Cocina.html">Cocina</a></li>
                            <li><a class="dropdown-item" href="Oficina.html">Oficina</a></li>
                        </ul>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="#!">Ofertas</a></li>
                    <li class="nav-item"><a class="nav-link" href="#!">Contacto</a></li>
                </ul>
                <form class="d-flex" action="carrito.html">
                    <button class="btn btn-outline-dark" type="submit">
                        <i class="bi-cart-fill me-1"></i>
                        Carrito
                        <span class="badge bg-dark text-white ms-1 rounded-pill" id="cart-count">0</span>
                    </button>
                </form>
            </div>
        </div>
    </nav>

    <!-- Encabezado de página-->
    <header class="bg-dark py-5"
        style="background-image: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1605602558878-ebd60c6ae9cf?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80'); background-size: cover; background-position: center;">
        <div class="container px-4 px-lg-5 my-4">
            <div class="text-center text-white">
                <h1 class="display-5 fw-bolder">Tu Carrito</h1>
                <p class="lead fw-normal text-white-50 mb-0">Revisa y confirma tu compra</p>
            </div>
        </div>
    </header>

    <!-- Contenido principal del carrito -->
    <section class="py-5">
        <div class="container px-4 px-lg-5">
            
            <!-- Carrito vacío (oculto por defecto) -->
            <div id="empty-cart" class="alert alert-info text-center py-4" style="display: none;">
                <i class="bi bi-cart-x fs-1 d-block mb-3"></i>
                <h4>Tu carrito está vacío</h4>
                <p class="mb-3">¡Explora nuestros productos y encuentra lo que necesitas!</p>
                <a href="Tiendaconestilo.html" class="btn btn-dark">Ver productos</a>
            </div>

            <!-- Carrito con productos (visible por defecto) -->
            <div id="cart-with-items">
                <div class="row">
                    <!-- Columna izquierda: Lista de productos -->
                    <div class="col-lg-8 mb-4 mb-lg-0">
                        <div class="card shadow-sm">
                            <div class="card-header bg-white py-3">
                                <h5 class="mb-0">Productos en tu carrito (<span id="cart-items-count">0</span>)</h5>
                            </div>
                            <div class="card-body p-0" id="cart-items-container">
                                <!-- Los productos se cargarán dinámicamente con JavaScript -->
                                <div class="text-center py-4 text-muted">
                                    No hay productos en el carrito
                                </div>
                            </div>
                            <div class="card-footer bg-white py-3">
                                <a href="Tiendaconestilo.html" class="text-decoration-none">
                                    <i class="bi bi-arrow-left me-1"></i> Seguir comprando
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Columna derecha: Resumen del pedido -->
                    <div class="col-lg-4">
                        <div class="card shadow-sm">
                            <div class="card-header bg-white py-3">
                                <h5 class="mb-0">Resumen del pedido</h5>
                            </div>
                            <div class="card-body">
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Subtotal (<span id="subtotal-items">0</span> productos):</span>
                                    <span class="fw-bold" id="subtotal-price">0,00 €</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Envío:</span>
                                    <span class="text-success" id="shipping-cost">Gratis</span>
                                </div>
                                <hr>
                                <div class="d-flex justify-content-between mb-3">
                                    <span class="h5 fw-bold">Total:</span>
                                    <span class="h5 fw-bold" id="total-price">0,00 €</span>
                                </div>
                                <div class="d-grid gap-2">
                                    <button class="btn btn-dark btn-lg" type="button" id="checkout-btn" disabled>
                                        Proceder al pago
                                    </button>
                                    <a href="Tiendaconestilo.html" class="btn btn-outline-secondary" type="button">
                                        Seguir comprando
                                    </a>
                                </div>
                                <p class="text-muted small text-center mt-3 mb-0">
                                    <i class="bi bi-shield-lock me-1"></i> Pago seguro
                                </p>
                            </div>
                        </div>
                        <!-- Cupón de descuento -->
                        <div class="card mt-3 shadow-sm">
                            <div class="card-body">
                                <h6 class="mb-3">¿Tienes un cupón?</h6>
                                <div class="input-group">
                                    <input type="text" class="form-control" placeholder="Código de descuento" id="coupon-code">
                                    <button class="btn btn-outline-dark" type="button" id="apply-coupon">Aplicar</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Productos sugeridos -->
